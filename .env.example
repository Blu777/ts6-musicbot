# ──────────────────────────────────────────────────────────────────────────
# TS6 MusicBot — configuración
# Copia este archivo como `.env` y completa los valores.
# ──────────────────────────────────────────────────────────────────────────

# ── Servidor TeamSpeak 6 ────────────────────────────────────────────────────
TS_SERVER_HOST=tu-servidor.cl
TS_SERVER_PORT=9988
TS_SERVER_PASSWORD=
TS_CHANNEL=NombreDelCanal
TS_BOT_NICKNAME=MusicBot

# ── WebQuery HTTP (envío de mensajes de texto) ──────────────────────────────
# El API key se genera desde la UI de administración del servidor TS6.
TS_WEBQUERY_HOST=tu-servidor.cl
TS_WEBQUERY_PORT=10081
TS_WEBQUERY_APIKEY=

# ── SSH ServerQuery (recepción de eventos de chat) ──────────────────────────
# Crea el usuario con `queryloginadd client_login_name=musicbot` y otorga
# el grupo sgid=2 (Admin Server Query) para obtener b_virtualserver_notify_register.
TS_QUERY_PORT=10012
TS_QUERY_USERNAME=musicbot
TS_QUERY_PASSWORD=

# ── Audio ───────────────────────────────────────────────────────────────────
AUDIO_VOLUME=85                     # Volumen inicial (0–100)
PULSE_SINK_NAME=musicbot_sink       # Cambia si tienes otro sink con el mismo nombre
AUDIO_CACHE_DIR=/data/cache         # Directorio de cache de yt-dlp dentro del contenedor
MAX_PLAYLIST_ITEMS=100              # Limite al resolver playlists (!playlist)

# ── Runtime ─────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO                      # DEBUG | INFO | WARNING | ERROR
AUTO_UPDATE_YT_DLP=1                # 1 = hacer pip install -U yt-dlp al arrancar

# ── TrueNAS / permisos (sólo para docker-compose, ignorado en TrueNAS UI) ──
PUID=1000
PGID=1000
